CREATE TABLE CIDADE(ID_CIDADE INTEGER NOT NULL PRIMARY KEY,
NOME_CIDADE VARCHAR(50),
UF_CIDADE CHAR(2));
CREATE TABLE ESPECIALIDADE(ID_ESP INTEGER NOT NULL PRIMARY KEY,
DESC_ESP VARCHAR(50));
CREATE TABLE CONVENIO(ID_CONVENIO INTEGER NOT NULL PRIMARY KEY,
NOME_CONVENIO VARCHAR(50));
CREATE TABLE PACIENTE(ID_PACIENTE INTEGER NOT NULL PRIMARY KEY,
NOME_PACIENTE VARCHAR(60),
END_PACIENTE VARCHAR(70),
FONERES_PACIENTE CHAR(11),
FONECEL_PACIENTE CHAR(11),
SEXO_PACIENTE CHAR(1),
CIDADE_PACIENTE INTEGER,
FOREIGN KEY(CIDADE_PACIENTE) REFERENCES CIDADE(ID_CIDADE));
CREATE TABLE MEDICO(ID_MEDICO INTEGER NOT NULL PRIMARY KEY,
NOME_MEDICO VARCHAR(60),
FONERES_MEDICO CHAR(11),
FONE_CEL_MEDICO CHAR(11),
ESP_MEDICO INTEGER,
FOREIGN KEY(ESP_MEDICO) REFERENCES ESPECIALIDADE(ID_ESP));
CREATE TABLE CONSULTA(ID_CONSULTA INTEGER NOT NULL PRIMARY KEY,
DATA_CONSULTA DATE,
PERIODO_CONSULTA VARCHAR(20),
CONVENIO_CONSULTA INTEGER,
MEDICO_CONSULTA INTEGER,
PACIENTE_CONSULTA INTEGER,
FOREIGN KEY(CONVENIO_CONSULTA) REFERENCES CONVENIO(ID_CONVENIO),
FOREIGN KEY(MEDICO_CONSULTA) REFERENCES MEDICO(ID_MEDICO),
FOREIGN KEY(PACIENTE_CONSULTA) REFERENCES PACIENTE(ID_PACIENTE));
